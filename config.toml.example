# ============================================================
# ZHS 智慧树自动刷课配置文件
# ============================================================
# 复制此文件为 config.toml 并填入实际值
# 配置项留空或使用默认值即可跳过

# ============================================================
# 基础设置
# ============================================================

# 是否保存 Cookie（避免重复登录）
save_cookies = true

# 刷课时间限制（分钟，0 = 不限制）
# 超过时间限制后自动跳过当前课程
limit = 0

# 视频结束阈值（0.0-1.0，默认 0.91）
# 视频播放进度超过此比例视为已完成
threshold = 0.91

# ============================================================
# 视频播放速度
# ============================================================

[video]
# 知到视频播放速度（默认 1.5，最高 2.0）
zhidao_speed = 1.5

# Hike 视频播放速度（默认 1.25，最高 2.0）
hike_speed = 1.25

# AI 课程视频播放速度（默认 1.5，最高 2.0）
ai_speed = 1.5

# ============================================================
# 作业配置（知到作业功能）
# ============================================================

[homework]
# 作业达标阈值（0-100，默认 100）
# 作业得分率低于此值会触发重做
threshold = 100

# 最大重做次数（默认 0 = 无限次）
# 超过此次数后跳过该作业
max_submit = 0

# 每题保存后延迟时间（秒）
# 实际延迟在 min 和 max 之间随机，防止请求过快触发风控
delay_min = 1.0
delay_max = 2.0

# 扫描作业列表分页大小（默认 100）
page_size = 100

# AI 课程作业跳过阈值（默认 90）
# ai智慧课程的掌握度 > 此值则跳过该作业
ai_homework_threshold = 90

# ============================================================
# 显示设置
# ============================================================

[display]
# 日志级别: DEBUG, INFO, WARNING, ERROR
log_level = "INFO"

# ============================================================
# 代理设置
# ============================================================

[proxies]
# HTTP 代理地址（留空则不使用代理）
http = ""

# HTTPS 代理地址（留空则不使用代理）
https = ""

# ============================================================
# 二维码设置
# ============================================================

[qr]
# 二维码图片保存路径（留空则使用默认目录）
image_path = ""

# ============================================================
# AI 配置（用于 AI 课程自动答题）
# ============================================================

[ai]
# ai智慧课程可使用的智慧树内置 AI
# 是否使用智慧树内置 AI（默认开启）
# 设为 false 则使用下方自定义 OpenAI 兼容接口
use_zhidao_ai = true

# OpenAI 兼容 API Key（仅 use_zhidao_ai = false 时需要）
# 支持 DeepSeek 等兼容接口
api_key = ""

# API Base URL（仅 use_zhidao_ai = false 时生效）
base_url = "https://api.openai.com/v1"

# 模型名称（仅 use_zhidao_ai = false 时生效）
model = "gpt-4o-mini"

# 最大 Token 数
max_token = 27900

# ============================================================
# 加密密钥（一般无需修改）
# ============================================================

[crypto]
iv = "1g3qqdh4jvbskb9x"
home_key = "7q9oko0vqb3la20r"
video_key = "azp53h0kft7qi78q"
qa_key = "kcGOlISPkYKRksSK"
ai_key = "hw2fdlwcj4cs1mx7"
exam_key = "onbfhdyvz8x7otrp"
hike_salt = "o6xpt3b#Qy$Z"
ev_key = "zzpttjd"
ai_sign_prefix = "8ZflKEagfL"

# ============================================================
# API URL（一般无需修改）
# ============================================================

[urls]
base = "https://onlineservice-api.zhihuishu.com"
passport = "https://passport.zhihuishu.com"
study = "https://studyservice-api.zhihuishu.com"
hike = "https://hike.zhihuishu.com"
ai = "https://kg-ai-run.zhihuishu.com"
newbase = "https://newbase.zhihuishu.com"
homework = "https://studentexam-api.zhihuishu.com"
ai_analysis = "https://ai-course-assistant-api.zhihuishu.com"